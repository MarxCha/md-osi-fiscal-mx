{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://md-osi-fiscal-mx/schemas/domain.schema.json",
  "title": "Dominio semántico fiscal",
  "type": "object",
  "required": ["id", "nombre", "version", "descripcion", "terminos"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Identificador snake_case del dominio (ej: iva_cobrado, isr, diot)"
    },
    "nombre": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "descripcion": {
      "type": "string",
      "minLength": 10
    },
    "terminos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "nombre", "definicion"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "nombre": { "type": "string" },
          "definicion": { "type": "string", "minLength": 10 },
          "base_legal": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          },
          "sinonimos": {
            "type": "array",
            "items": { "type": "string" }
          },
          "antonimos": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tipo": {
            "type": "string",
            "enum": ["concepto", "monto", "fecha", "estado", "evento", "documento"]
          },
          "ejemplos": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "reglas_relacionadas": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^RN-[0-9]{3}$"
      }
    }
  }
}
